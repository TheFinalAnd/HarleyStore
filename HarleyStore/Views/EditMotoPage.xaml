<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="HarleyStore.Views.EditMotoPage"
             Title="Editar Moto"
             BackgroundColor="#111111">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="18">
            <Label Text="Editar Moto"
                   TextColor="White"
                   FontSize="34"
                   FontAttributes="Bold" />

            <Frame Style="{StaticResource CardFrameStyle}">
                <VerticalStackLayout Spacing="12">
                    <Label Text="Detalles de la Moto"
                           TextColor="White"
                           FontSize="28"
                           FontAttributes="Bold"/>

                    <Label Text="Marca" TextColor="White"/>
                    <Picker x:Name="MarcaPicker"
                            Title="Seleccione una marca"
                            TitleColor="#AAAAAA"
                            TextColor="White"
                            BackgroundColor="#2E2E2E"
                            SelectedIndexChanged="OnMarcaChanged"
                            ItemDisplayBinding="{Binding NombreMarca}" />

                    <Label Text="Modelo" TextColor="White"/>
                    <Picker x:Name="ModeloPicker"
                            Title="Seleccione un modelo"
                            TitleColor="#AAAAAA"
                            TextColor="White"
                            BackgroundColor="#2E2E2E"
                            ItemDisplayBinding="{Binding NombreModelo}" />

                    <Label Text="Precio" TextColor="White"/>
                    <Label Text="Precio (miles)" TextColor="White" />
                    <Entry x:Name="PrecioEntry"
               Style="{StaticResource EntryStyle}"
               Keyboard="Numeric"
               Placeholder="15"/>

                    <Label Text="Millas" TextColor="White"/>
                    <Entry x:Name="MillasEntry"
                           Style="{StaticResource EntryStyle}"
                           Keyboard="Numeric"
                           Placeholder="5000"/>

                    <Label Text="Prima mínima (miles)" TextColor="White" />
                    <Entry x:Name="MinPrimaEntry" Style="{StaticResource EntryStyle}" Keyboard="Numeric" Placeholder="3" />

                    <Label Text="Interés mínimo (%)" TextColor="White" />
                    <Entry x:Name="MinInteresEntry" Style="{StaticResource EntryStyle}" Keyboard="Numeric" Placeholder="1.5" />

                    <Label Text="Descripción" TextColor="White"/>
                    <Editor x:Name="DescripcionEditor"
                            BackgroundColor="#2E2E2E"
                            TextColor="White"
                            HeightRequest="130"
                            Placeholder="Describe tu moto..."
                            Completed="OnGuardarCompleted"/>
                </VerticalStackLayout>
            </Frame>

            <Frame Style="{StaticResource CardFrameStyle}">
                <VerticalStackLayout Spacing="12">
                    <Label Text="Foto actual / nueva foto"
                           TextColor="White"
                           FontSize="28"
                           FontAttributes="Bold"/>

                    <Image x:Name="FotoPreview"
                           HeightRequest="220"
                           Aspect="AspectFit"
                           BackgroundColor="#1A1A1A" />

                    <Button Text="Seleccionar nueva foto"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Clicked="OnSeleccionarFotoClicked"/>
                </VerticalStackLayout>
            </Frame>

            <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                <Button Text="Cancelar"
                        Grid.Column="0"
                        BackgroundColor="#444444"
                        TextColor="White"
                        CornerRadius="24"
                        HeightRequest="52"
                        Clicked="OnCancelarClicked"/>

                <Button Text="Guardar cambios"
                        Grid.Column="1"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Clicked="OnGuardarClicked"/>
            </Grid>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>