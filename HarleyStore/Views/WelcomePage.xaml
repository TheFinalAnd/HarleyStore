<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="HarleyStore.Views.WelcomePage"
             Shell.NavBarIsVisible="False">
    <Grid Padding="26" RowDefinitions="Auto,Auto,*,Auto">
        <Label Text="HarleyStore"
               FontSize="34"
               FontAttributes="Bold"
               TextColor="White"
               HorizontalOptions="Center"
               Margin="0,20,0,0" />

        <Label Grid.Row="1"
               Text="Buy and sell premium motorcycles."
               FontSize="18"
               TextColor="#DDDDDD"
               HorizontalOptions="Center"
               Margin="0,12,0,24" />

        <Frame Grid.Row="2"
               CornerRadius="24"
               Padding="0"
               HasShadow="False"
               BackgroundColor="#151515"
               BorderColor="#2D2D2D">
            <Image Source="mainimage.png" Aspect="AspectFill" />
        </Frame>

        <Button Grid.Row="3"
                Text="Get started"
                Style="{StaticResource PrimaryButtonStyle}"
                BackgroundColor="White"
                TextColor="Black"
                Margin="18,24,18,26"
                Clicked="OnGetStartedClicked"/>
    </Grid>
</ContentPage>