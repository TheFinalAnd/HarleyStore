<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="HarleyStore.Views.NotificationsPage"
             Title="Notificaciones"
             BackgroundColor="#111111">

    <CollectionView x:Name="NotificacionesCollectionView"
                    Margin="12"
                    ItemsLayout="VerticalList">
        <CollectionView.ItemTemplate>
            <DataTemplate>
                <Frame BackgroundColor="#1A1A1A" CornerRadius="12" Padding="12" Margin="0,6">
                    <VerticalStackLayout>
                        <Label Text="{Binding Asunto}" TextColor="White" FontAttributes="Bold"/>
                        <Label Text="{Binding Mensaje}" TextColor="#CCCCCC" FontSize="14"/>
                        <Label Text="{Binding Fecha}" TextColor="#888888" FontSize="12"/>
                    </VerticalStackLayout>
                </Frame>
            </DataTemplate>
        </CollectionView.ItemTemplate>
    </CollectionView>
</ContentPage>
