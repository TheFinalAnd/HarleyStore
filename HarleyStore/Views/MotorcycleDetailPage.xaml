<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:conv="clr-namespace:HarleyStore.Views.Converters"
             x:Class="HarleyStore.Views.MotorcycleDetailPage"
             Title="Detalle"
             BackgroundColor="#111111">

    <ContentPage.Resources>
        <ResourceDictionary>
            <conv:EstadoToColorConverter x:Key="EstadoToColor" />
            <conv:EstadoToTextConverter x:Key="EstadoToTextConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <ScrollView>
        <VerticalStackLayout Padding="18" Spacing="16">

            <Frame BackgroundColor="#1A1A1A"
                   CornerRadius="22"
                   Padding="10"
                   HasShadow="False"
                   BorderColor="#2E2E2E">
                <Grid HeightRequest="280">
                    <Image x:Name="MotoImage"
                           HeightRequest="260"
                           Aspect="AspectFit"
                           HorizontalOptions="Fill"
                           VerticalOptions="Fill"
                           BackgroundColor="#1A1A1A" />
                </Grid>
            </Frame>

            <Label x:Name="TituloLabel"
                   TextColor="White"
                   FontSize="34"
                   FontAttributes="Bold" />

            <Label x:Name="DescripcionLabel"
                   TextColor="White"
                   FontSize="18" />

            <HorizontalStackLayout Spacing="12">
                <Label x:Name="PrimaMinLabel" TextColor="#CCCCCC" FontSize="14" />
                <Label x:Name="InteresMinLabel" TextColor="#CCCCCC" FontSize="14" />
            </HorizontalStackLayout>

            <BoxView HeightRequest="1" Color="#444444"/>

            <Label x:Name="EngineLabel"
                   TextColor="White"
                   FontSize="18" />

            <Label x:Name="PowerLabel"
                   TextColor="White"
                   FontSize="18" />

            <Label x:Name="MileageLabel"
                   TextColor="White"
                   FontSize="18" />

            <Label x:Name="PriceLabel"
                   TextColor="White"
                   FontSize="18"
                   FontAttributes="Bold" />

            <Label x:Name="OfertasHeaderLabel"
                   TextColor="#CCCCCC"
                   FontSize="16"
                   Text="Ofertas"
                   Margin="0,12,0,0" />

            <CollectionView x:Name="OfertasCollectionView" HeightRequest="120" SelectionMode="Single" SelectionChanged="OnOfertaSelected">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame CornerRadius="8" Padding="8" Margin="0,6">
                            <HorizontalStackLayout Spacing="12" BackgroundColor="#1A1A1A" Padding="8">
                                <BoxView WidthRequest="8" HeightRequest="40" VerticalOptions="Center" Color="{Binding IdEstado, Converter={StaticResource EstadoToColor}}" />
                                <VerticalStackLayout>
                                    <Label Text="{Binding PrecioOfertado, StringFormat='{0:C}'}" TextColor="White" FontAttributes="Bold"/>
                                <Label Text="{Binding Fecha, StringFormat='{0:yyyy-MM-dd}'}" TextColor="#888888"/>
                                <Label Text="{Binding IdEstado, Converter={StaticResource EstadoToTextConverter}}" TextColor="#CCCCCC" FontSize="12" />
                                <Label Text="{Binding PrecioPorCuota, StringFormat='Precio p/ cuota: {0:C}'}" TextColor="#CCCCCC" FontSize="12" />
                                </VerticalStackLayout>
                            </HorizontalStackLayout>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Grid ColumnDefinitions="*,*"
                  ColumnSpacing="10"
                  Margin="0,14,0,0">

                

                <Grid ColumnDefinitions="*,*,*"
      ColumnSpacing="10"
      Margin="0,10,0,0">

                    <Button x:Name="EditButton"
            Text="Editar"
            Grid.Column="0"
            IsVisible="False"
            Style="{StaticResource PrimaryButtonStyle}"
            Clicked="OnEditarClicked"/>

                    <Button x:Name="DeleteButton"
            Text="Eliminar"
            Grid.Column="1"
            IsVisible="False"
            BackgroundColor="Red"
            TextColor="White"
            Clicked="OnEliminarClicked"/>

                    <Button x:Name="ContactarButton"
            Text="Contactar"
            Grid.Column="0"
            IsVisible="False"
            Style="{StaticResource PrimaryButtonStyle}"
            Clicked="OnContactarClicked"/>

                    <Button x:Name="OfertarButton"
            Text="Hacer Oferta"
            Grid.Column="1"
            IsVisible="False"
            Style="{StaticResource PrimaryButtonStyle}"
            Clicked="OnHacerOfertarClicked"/>

                    <Button x:Name="FavoritoButton"
Text="Favoritos"
                            Grid.Column="2"
Style="{StaticResource PrimaryButtonStyle}"
Clicked="OnFavoritoClicked"
Margin="0,10,0,0"/>
                </Grid>
            </Grid>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>