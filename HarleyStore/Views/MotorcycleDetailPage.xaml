<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="HarleyStore.Views.MotorcycleDetailPage"
             Title="Detalle"
             BackgroundColor="#111111">

    <ScrollView>
        <VerticalStackLayout Padding="18" Spacing="16">

            <Frame BackgroundColor="#1A1A1A"
                   CornerRadius="22"
                   Padding="10"
                   HasShadow="False"
                   BorderColor="#2E2E2E">
                <Grid HeightRequest="280">
                    <Image x:Name="MotoImage"
                           HeightRequest="260"
                           Aspect="AspectFit"
                           HorizontalOptions="Fill"
                           VerticalOptions="Fill"
                           BackgroundColor="#1A1A1A" />
                </Grid>
            </Frame>

            <Label x:Name="TituloLabel"
                   TextColor="White"
                   FontSize="34"
                   FontAttributes="Bold" />

            <Label x:Name="DescripcionLabel"
                   TextColor="White"
                   FontSize="18" />

            <BoxView HeightRequest="1" Color="#444444"/>

            <Label x:Name="EngineLabel"
                   TextColor="White"
                   FontSize="18" />

            <Label x:Name="PowerLabel"
                   TextColor="White"
                   FontSize="18" />

            <Label x:Name="MileageLabel"
                   TextColor="White"
                   FontSize="18" />

            <Label x:Name="PriceLabel"
                   TextColor="White"
                   FontSize="18"
                   FontAttributes="Bold" />

            <Grid ColumnDefinitions="*,*"
                  ColumnSpacing="10"
                  Margin="0,14,0,0">

                <Button Text="Favoritos"
                        Grid.Column="0"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Clicked="OnFavoritoClicked"/>

                <Button Text="Contactar"
                        Grid.Column="1"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Clicked="OnContactarClicked"/>
            </Grid>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>