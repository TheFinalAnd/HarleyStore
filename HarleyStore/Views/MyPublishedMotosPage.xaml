<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="HarleyStore.Views.MyPublishedMotosPage"
             Title="Mis motos"
             BackgroundColor="#111111">

    <Grid Padding="18">
        <CollectionView x:Name="MisMotosCollectionView"
                        SelectionChanged="OnMotoSelected">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Style="{StaticResource CardFrameStyle}" Margin="0,0,0,12">
                        <VerticalStackLayout Spacing="10">
                            <Image Source="{Binding FotoMostrada}"
                                   HeightRequest="160"
                                   Aspect="AspectFit"
                                   BackgroundColor="#1A1A1A"/>

                            <Label Text="{Binding Modelo.NombreModelo}"
                                   TextColor="White"
                                   FontSize="22"
                                   FontAttributes="Bold"/>

                            <Label Text="{Binding PrecioPublicado, StringFormat='${0:N0}'}"
                                   TextColor="White"
                                   FontAttributes="Bold"/>

                            <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                                <Button Text="Editar"
                                        Grid.Column="0"
                                        BackgroundColor="#444444"
                                        TextColor="White"
                                        Clicked="OnEditarClicked"
                                        CommandParameter="{Binding .}" />

                                <Button Text="Eliminar"
                                        Grid.Column="1"
                                        BackgroundColor="#C62828"
                                        TextColor="White"
                                        Clicked="OnEliminarClicked"
                                        CommandParameter="{Binding .}" />
                            </Grid>
                        </VerticalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>