<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="HarleyStore.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:HarleyStore.Views"
    Shell.FlyoutBehavior="Disabled"
    Shell.NavBarIsVisible="False">

    <ShellContent Route="welcome" ContentTemplate="{DataTemplate views:WelcomePage}" />
    <ShellContent Route="login" ContentTemplate="{DataTemplate views:LoginPage}" />
    <ShellContent Route="register" ContentTemplate="{DataTemplate views:RegisterPage}" />
    <ShellContent Route="home" ContentTemplate="{DataTemplate views:HomePage}" />
    <ShellContent Route="notifications" ContentTemplate="{DataTemplate views:NotificationsPage}" />
    <ShellContent Route="myoffers" ContentTemplate="{DataTemplate views:MyOffersPage}" />
    <ShellContent Route="mypayments" ContentTemplate="{DataTemplate views:MyPaymentsPage}" />
</Shell>